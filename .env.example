# ───────────────────────────────────────────────────────────
# Painel Admin Agzap — variáveis de ambiente
# Copie este arquivo para `.env` e preencha com os valores reais.
# ───────────────────────────────────────────────────────────

# Supabase
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=
NUXT_SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# OpenAI
OPENAI_API_KEY=

# UaZapi (WhatsApp)
UAZAPI_BASE_URL=https://agzap.uazapi.com
UAZAPI_ADMIN_TOKEN=

# Stripe (Live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Meta WhatsApp Business API
META_APP_ID=
META_CONFIG_ID=
META_SYSTEM_TOKEN=
META_APP_SECRET=
META_ENABLED=true

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
